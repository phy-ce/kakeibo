# Gemini API 키 — 영수증 OCR 에 필요. 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Flask 세션 서명 키 — 아무 랜덤 문자열. 다음 명령으로 생성 가능:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# 서버 포트 (기본 5000). 다른 인스턴스와 동시 운영할 때 변경.
FLASK_PORT=5000

# (선택) Gemini 모델 ID — 기본은 gemini-flash-latest
# GEMINI_MODEL=gemini-flash-latest
